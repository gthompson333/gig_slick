rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: resolve venue ownership ──
    function isVenueOwner(venueId) {
      return request.auth != null
        && request.auth.uid == get(/databases/$(database)/documents/venues/$(venueId)).data.ownerId;
    }

    // ── Venues ──────────────────────────────────────────────
    // Public read: performers need venue name from shared links.
    // Write: only the authenticated owner.
    match /venues/{venueId} {
      allow read: if true;

      allow create: if request.auth != null
        && request.resource.data.ownerId == request.auth.uid;

      allow update, delete: if request.auth != null
        && request.auth.uid == resource.data.ownerId;
    }

    // ── Gigs ────────────────────────────────────────────────
    // Public read: performers access gig details via shared links.
    // All writes: only the venue owner.
    match /gigs/{gigId} {
      allow read: if true;

      allow create: if request.auth != null
        && isVenueOwner(request.resource.data.venueId);

      allow update, delete: if isVenueOwner(resource.data.venueId);

      // ── Applications (subcollection) ────────────────────
      // Create: anyone (performers submit via unauthenticated web form).
      // Read/update/delete: only the venue owner.
      match /applications/{applicationId} {
        allow create: if true;

        allow read, update, delete: if isVenueOwner(
          get(/databases/$(database)/documents/gigs/$(gigId)).data.venueId
        );
      }
    }
  }
}
